generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  POSTER
  SEEKER
}

enum ListingType {
  JOB
  GIG
  BOUNTY
}

enum ListingStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
  COMPLETED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum ContractStatus {
  ACTIVE
  COMPLETED
  DISPUTED
  CANCELLED
}

enum EscrowStatus {
  PENDING
  FUNDED
  RELEASED
  REFUNDED
  DISPUTED
}

enum VerificationType {
  EMAIL
  PHONE
  ORGANIZATION
  IDENTITY
  ADMIN_BADGE
}

// ─── Auth.js required models ───────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core models ───────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  emailVerified    DateTime?
  hashedPassword   String?
  image            String?
  bio              String?   @db.Text
  title            String?
  location         String?
  chapter          String?
  membershipLevel  String?
  role             UserRole  @default(SEEKER)
  stripeAccountId  String?
  stripeCustomerId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts              Account[]
  sessions              Session[]
  listings              Listing[]
  applications          Application[]
  contractsAsPoster     Contract[]                @relation("PosterContracts")
  contractsAsSeeker     Contract[]                @relation("SeekerContracts")
  reviewsGiven          Review[]                  @relation("ReviewAuthor")
  reviewsReceived       Review[]                  @relation("ReviewSubject")
  sentMessages          Message[]                 @relation("MessageSender")
  conversations         ConversationParticipant[]
  notifications         Notification[]
  verifications         Verification[]
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  icon     String?
  listings Listing[]
}

model Listing {
  id          String        @id @default(cuid())
  title       String
  description String        @db.Text
  type        ListingType
  status      ListingStatus @default(DRAFT)
  budgetMin    Decimal?      @db.Decimal(10, 2)
  budgetMax    Decimal?      @db.Decimal(10, 2)
  budgetFixed  Decimal?      @db.Decimal(10, 2)
  hourlyRate   Decimal?      @db.Decimal(10, 2)
  budgetKind   String?       // "fixed", "range", "hourly"
  location     String?
  isRemote    Boolean       @default(false)
  deadline    DateTime?
  tags        String[]
  categoryId  String?
  category    Category?     @relation(fields: [categoryId], references: [id])
  userId      String
  user        User          @relation(fields: [userId], references: [id])

  applications Application[]
  contracts    Contract[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status])
  @@index([categoryId])
  @@index([userId])
}

model Application {
  id          String            @id @default(cuid())
  coverLetter String?           @db.Text
  bidAmount   Decimal?          @db.Decimal(10, 2)
  status      ApplicationStatus @default(PENDING)
  listingId   String
  listing     Listing           @relation(fields: [listingId], references: [id])
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  contract    Contract?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([listingId, userId])
}

model Contract {
  id            String         @id @default(cuid())
  status        ContractStatus @default(ACTIVE)
  agreedAmount  Decimal        @db.Decimal(10, 2)
  platformFee   Decimal        @db.Decimal(10, 2)
  deadline      DateTime?
  completedAt   DateTime?
  listingId     String
  listing       Listing        @relation(fields: [listingId], references: [id])
  posterId      String
  poster        User           @relation("PosterContracts", fields: [posterId], references: [id])
  seekerId      String
  seeker        User           @relation("SeekerContracts", fields: [seekerId], references: [id])
  applicationId String         @unique
  application   Application    @relation(fields: [applicationId], references: [id])
  escrow        Escrow?
  reviews       Review[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Escrow {
  id                    String       @id @default(cuid())
  status                EscrowStatus @default(PENDING)
  amount                Decimal      @db.Decimal(10, 2)
  stripePaymentIntentId String?
  stripeTransferId      String?
  fundedAt              DateTime?
  releasedAt            DateTime?
  contractId            String       @unique
  contract              Contract     @relation(fields: [contractId], references: [id])
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
}

model Review {
  id         String   @id @default(cuid())
  rating     Int
  comment    String?  @db.Text
  authorId   String
  author     User     @relation("ReviewAuthor", fields: [authorId], references: [id])
  subjectId  String
  subject    User     @relation("ReviewSubject", fields: [subjectId], references: [id])
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([authorId, contractId])
}

model Conversation {
  id           String                    @id @default(cuid())
  participants ConversationParticipant[]
  messages     Message[]
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  lastReadAt     DateTime?

  @@unique([userId, conversationId])
}

model Message {
  id             String       @id @default(cuid())
  content        String       @db.Text
  senderId       String
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model Verification {
  id         String           @id @default(cuid())
  type       VerificationType
  verified   Boolean          @default(false)
  data       Json?
  userId     String
  user       User             @relation(fields: [userId], references: [id])
  verifiedAt DateTime?
  createdAt  DateTime         @default(now())

  @@unique([userId, type])
}
